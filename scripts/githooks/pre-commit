#!/bin/bash
# =================================================================
# Pre-commit Hook — Quick type + lint check before commit
# Install: git config core.hooksPath scripts/githooks
# =================================================================

set -e

echo "=== Pre-commit: TypeScript check ==="
pnpm tsc --noEmit
if [ $? -ne 0 ]; then
    echo "FAIL: Type check failed. Please fix errors before committing."
    exit 1
fi
echo "PASS: Type check successful."

echo ""
echo "=== Pre-commit: Biome check ==="
pnpm biome check src tests
if [ $? -ne 0 ]; then
    echo "FAIL: Biome violations found. Please fix (or run 'pnpm biome check --write src tests') before committing."
    exit 1
fi
echo "PASS: Biome passed."

echo ""
echo "Pre-commit checks passed."
